PORT=5000
NODE_ENV=development

# Optional Clerk publishable key (used for authentication)
# - If omitted, the app will run in an "unauthenticated dev mode" where
#   Clerk's Sign In / User UI is disabled but the visualizers still work.
# - To enable Clerk for local development, set this to your Clerk publishable key:
#   VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_CLERK_PUBLISHABLE_KEY=
